{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Team Bookmarks",
  "description": "Schema for team-bookmarks YAML files. See https://github.com/slashgear/team-bookmarks",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "folders": {
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/$defs/__schema0"
      }
    }
  },
  "required": ["name", "folders"],
  "additionalProperties": false,
  "$defs": {
    "__schema0": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "links": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string"
              },
              "url": {
                "type": "string"
              }
            },
            "required": ["label", "url"],
            "additionalProperties": false
          }
        },
        "folders": {
          "default": [],
          "type": "array",
          "items": {
            "$ref": "#/$defs/__schema0"
          }
        }
      },
      "required": ["name", "links", "folders"],
      "additionalProperties": false
    }
  }
}
